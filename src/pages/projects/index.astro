---
import { getCollection } from 'astro:content'
import { BlueprintDivider } from '@pristine-machine/ui'
import { Sparkles } from '@lucide/astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import ProjectCard from '@/components/ProjectCard.astro'

const all = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title)
)
const featured = all.filter((project) => project.data.featured)
const rest = all.filter((project) => !project.data.featured)
---

<BaseLayout
  title="Projects"
  description="A selection of things Brian Lai has designed and built."
>
  <section class="px-6 pt-16 pb-12 sm:px-8 sm:pt-20">
    <SectionHeading
      eyebrow="Projects"
      title="Things I've built"
      accent="built"
      description="A selection of work, side projects, and experiments. Each one is a short writeup of what it is and how it came together."
    />
  </section>

  {
    featured.length > 0 && (
      <section class="px-6 pb-16 sm:px-8">
        <div class="mb-6 flex items-center gap-2">
          <Sparkles class="size-4 text-rose-600 dark:text-rose-400" aria-hidden="true" />
          <h2 class="font-mono text-xs font-medium uppercase tracking-widest text-mauve-600 dark:text-mauve-400">
            Featured
          </h2>
        </div>
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((project) => (
            <li class="h-full">
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    rest.length > 0 && (
      <>
        <BlueprintDivider ticked />
        <section class="px-6 py-16 sm:px-8 sm:py-20">
          <h2 class="mb-6 font-mono text-xs font-medium uppercase tracking-widest text-mauve-600 dark:text-mauve-400">
            {featured.length > 0 ? 'More projects' : 'All projects'}
          </h2>
          <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((project) => (
              <li class="h-full">
                <ProjectCard project={project} />
              </li>
            ))}
          </ul>
        </section>
      </>
    )
  }

  {
    all.length === 0 && (
      <section class="px-6 pb-20 sm:px-8">
        <p class="font-mono text-sm text-mauve-600 dark:text-mauve-400">
          No projects published yet. Check back soon.
        </p>
      </section>
    )
  }
</BaseLayout>
