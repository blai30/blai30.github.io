---
import SocialIcon from '@/components/SocialIcon.astro'
import { socials } from '@/site'
import { focusRing } from '@pristine-machine/ui'

type Props = {
  // 'icons' = compact square icon buttons; 'list' = icon + label + handle rows.
  variant?: 'icons' | 'list'
  class?: string
}

const { variant = 'icons', class: className } = Astro.props
---

{
  variant === 'icons' ? (
    <ul class:list={['flex flex-wrap items-center gap-2', className]}>
      {socials.map((social) => (
        <li>
          <a
            href={social.href}
            target={social.icon === 'mail' ? undefined : '_blank'}
            rel={social.icon === 'mail' ? undefined : 'noopener noreferrer'}
            aria-label={social.label}
            title={social.label}
            class:list={['grid size-10 place-items-center border border-mauve-300 bg-white text-mauve-700 transition-colors duration-200 hover:border-rose-400 hover:text-rose-600 hover:duration-0 dark:border-mauve-600 dark:bg-mauve-800 dark:text-mauve-300 dark:hover:border-rose-400 dark:hover:text-rose-400', focusRing]}
          >
            <SocialIcon name={social.icon} class="size-[1.15rem]" />
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <ul class:list={['flex flex-col gap-px border border-mauve-200 dark:border-mauve-700', className]}>
      {socials.map((social) => (
        <li>
          <a
            href={social.href}
            target={social.icon === 'mail' ? undefined : '_blank'}
            rel={social.icon === 'mail' ? undefined : 'noopener noreferrer'}
            class:list={['group flex items-center gap-4 bg-white px-4 py-3.5 transition-colors duration-200 hover:bg-mauve-50 hover:duration-0 dark:bg-mauve-800 dark:hover:bg-mauve-800/60', focusRing, 'focus-visible:ring-inset']}
          >
            <SocialIcon
              name={social.icon}
              class="size-5 text-mauve-600 transition-colors group-hover:duration-0 group-hover:text-rose-700 dark:text-mauve-400 dark:group-hover:text-rose-400"
            />
            <span class="flex-1 font-sans text-sm font-medium text-mauve-900 dark:text-mauve-100">
              {social.label}
            </span>
            <span class="font-mono text-xs text-mauve-600 dark:text-mauve-400">{social.handle}</span>
          </a>
        </li>
      ))}
    </ul>
  )
}
