---
type Props = {
  // Mono eyebrow, e.g. "02 / Skills".
  eyebrow: string
  title: string
  // One word within `title` rendered in italic accent; first match wins.
  accent?: string
  description?: string
  id?: string
}

const { eyebrow, title, accent, description, id } = Astro.props

// Split the title around the accent word so only that word is emphasized.
let before = title
let word = ''
let after = ''
if (accent && title.includes(accent)) {
  const index = title.indexOf(accent)
  before = title.slice(0, index)
  word = accent
  after = title.slice(index + accent.length)
}
---

<div class="flex flex-col gap-3" id={id}>
  <span class="font-mono text-xs font-medium uppercase tracking-widest text-mauve-600 dark:text-mauve-400">
    {eyebrow}
  </span>
  <h2 class="font-serif text-4xl leading-tight text-mauve-900 sm:text-5xl dark:text-mauve-100">
    {
      word ? (
        <>
          {before}
          <span class="italic text-rose-600 dark:text-rose-400">{word}</span>
          {after}
        </>
      ) : (
        title
      )
    }
  </h2>
  {
    description && (
      <p class="max-w-2xl text-base/7 text-mauve-600 dark:text-mauve-400 text-pretty">{description}</p>
    )
  }
</div>
