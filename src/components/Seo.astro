---
import { site, socials, skills } from '@/site'

type Props = {
  title?: string
  description?: string
  // Path or absolute URL to the share image; resolved against the site origin.
  image?: string
  type?: 'website' | 'article'
  publishedTime?: Date
  modifiedTime?: Date
  tags?: string[]
  noindex?: boolean
}

const {
  title,
  description = site.description,
  image = site.ogImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  noindex = false,
} = Astro.props

const pageTitle = title ? `${title} · ${site.name}` : site.name
const canonical = new URL(Astro.url.pathname, site.url)
const imageUrl = new URL(image, site.url)
const isArticle = type === 'article'
// A page-specific image (e.g. a project thumbnail) earns the large card; the
// small default favicon does not.
const hasCustomImage = Boolean(Astro.props.image)

// External profiles for the Person entity's sameAs (excludes mail and on-site links).
const sameAs = socials
  .filter((social) => social.href.startsWith('http') && !social.href.includes('blai30.github.io'))
  .map((social) => social.href)

const knowsAbout = skills.flatMap((group) => group.items.map((item) => item.name))

const personId = `${site.url}/#person`
const websiteId = `${site.url}/#website`

const graph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': personId,
    name: site.name,
    jobTitle: site.role,
    url: site.url,
    image: new URL('/favicon.png', site.url).href,
    description: site.tagline,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'San Francisco Bay Area',
      addressRegion: 'CA',
      addressCountry: 'US',
    },
    knowsAbout,
    sameAs,
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    name: site.name,
    url: site.url,
    description: site.description,
    inLanguage: 'en-US',
    publisher: { '@id': personId },
  },
]

// Only dated content is a BlogPosting; project writeups carry article OG tags
// without claiming to be posts.
if (isArticle && publishedTime) {
  graph.push({
    '@type': 'BlogPosting',
    headline: title,
    description,
    url: canonical.href,
    mainEntityOfPage: canonical.href,
    image: imageUrl.href,
    datePublished: publishedTime.toISOString(),
    dateModified: (modifiedTime ?? publishedTime).toISOString(),
    author: { '@id': personId },
    publisher: { '@id': personId },
    keywords: tags.length > 0 ? tags.join(', ') : undefined,
    inLanguage: 'en-US',
  })
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph }
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={site.name} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={`${title ?? site.name}, ${site.role}`} />
{isArticle && publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{isArticle && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
{isArticle && <meta property="article:author" content={site.name} />}
{isArticle && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content={hasCustomImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
