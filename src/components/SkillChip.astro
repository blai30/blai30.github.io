---
import { Icon } from 'astro-icon/components'
import { clsx } from 'clsx/lite'

type Props = {
  name: string
  // Iconify brand-logo name, e.g. 'logos:react'. A 'simple-icons:*' name is
  // monochrome and gets tinted to the foreground color.
  icon: string
  // Optional dedicated dark-mode logo, swapped in for `icon` on the dark canvas.
  iconDark?: string
  // Dark-mode filter for single colored logos that vanish on the dark canvas.
  dark?: 'invert' | 'white'
}

const { name, icon, iconDark, dark } = Astro.props

const base = 'size-12 shrink-0'
const isMono = (value: string) => value.startsWith('simple-icons:')
const filter =
  dark === 'invert' ? 'dark:invert' : dark === 'white' ? 'dark:brightness-0 dark:invert' : ''
---

<div
  class="flex h-full items-center gap-4 border border-mauve-300 px-4 py-4 transition-colors duration-200 hover:border-rose-400 hover:bg-mauve-200/40 hover:duration-0 dark:border-mauve-700 dark:hover:border-rose-400 dark:hover:bg-mauve-800/40"
>
  {
    iconDark ? (
      <>
        <Icon name={icon} class={clsx(base, isMono(icon) && 'text-mauve-900', 'dark:hidden')} />
        <Icon
          name={iconDark}
          class={clsx(base, isMono(iconDark) && 'text-mauve-100', 'hidden dark:block')}
        />
      </>
    ) : (
      <Icon name={icon} class={clsx(base, isMono(icon) && 'text-mauve-900 dark:text-mauve-100', filter)} />
    )
  }
  <span class="font-sans text-base font-medium text-mauve-900 dark:text-mauve-100">{name}</span>
</div>
